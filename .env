# Required: Redis connection URL.
# Examples:
# - Local no auth: redis://localhost:6379/0
# - Password auth: redis://:your_password@localhost:6379/0
# - ACL auth: rediss://username:password@your-redis-host:6379/0
REDIS_URL=redis://localhost:6379/0

# Required: absolute or relative path to policy yaml
POLICIES_FILE=./configs/policies.yaml

# Required: HTTP server port
PORT=8080

# Required: open or closed
FAILURE_MODE=open

# Required for POST /v1/admin/reload auth
ADMIN_SECRET=2a46b07b3a051df13973bb7a9982012993ab33fc7cee6e5386345e6ea9450192

# Optional: development or production
APP_ENV=development
