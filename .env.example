# Rate Limiter Backend Environment Configuration
# Copy this file to .env and adjust values as needed

# Redis connection URL (required)
REDIS_URL=redis://localhost:6379

# Path to policies YAML file (required)
POLICIES_FILE=./configs/policies.yaml

# HTTP API port (required)
PORT=8080

# Dedicated Prometheus scrape port (default: 9090). If equal to PORT, only one listener is used and GET /metrics is on that port.
METRICS_PORT=9090

# Failure mode: "open" (fail-open) or "closed" (fail-closed)
# open:  Allows requests if Redis fails (better availability)
# closed: Denies requests if Redis fails (better security)
FAILURE_MODE=open

# Admin secret for policy reload (set a strong random value)
# Generate with: openssl rand -base64 32
ADMIN_SECRET=my-super-secret-key-123

# Application environment: "development" or "production"
APP_ENV=development
