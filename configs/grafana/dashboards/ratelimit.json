  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "expr": "sum by (tenant) (rate(ratelimit_requests_total{result=\"allowed\"}[1m]))",
          "legendFormat": "{{tenant}}",
          "refId": "A"
        }
      ],
      "title": "Requests Per Second By Tenant",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(ratelimit_requests_total{result=\"denied\"}[1m])) / clamp_min(sum(rate(ratelimit_requests_total{result=~\"allowed|denied\"}[1m])), 1)",
          "legendFormat": "deny_rate",
          "refId": "A"
        }
      ],
      "title": "Deny Rate Percentage",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(ratelimit_redis_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(ratelimit_redis_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum(rate(ratelimit_redis_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C"}
      ],
      "title": "Redis Latency p50/p95/p99",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"min": 0, "max": 2}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "targets": [
        {
          "expr": "ratelimit_circuit_breaker_state",
          "legendFormat": "state",
          "refId": "A"
        }
      ],
      "title": "Circuit Breaker State",
      "type": "stat"
    }
